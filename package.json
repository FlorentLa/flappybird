{
  "name": "flappybird",
  "private": true,
  "version": "0.1.0",
  "description": "Flappy Bird HTML5 game with live global leaderboard (Cognito+AppSync+DynamoDB)",
  "workspaces": [
    "modules/web",
    "modules/api",
    "infra"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "synth": "cd infra && npx cdk synth --all -c env=demo -q",
    "deploy": "bash scripts/deploy.sh",
    "bootstrap-user": "bash scripts/bootstrap-user.sh"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
